{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev",
    "build": "npm run build:prod",
    "build:dev": "vue-tsc -b && vite build --mode development",
    "build:prod": "vue-tsc -b && vite build --mode production",
    "build:lib": "cross-env NODE_ENV=production webpack --config webpack.lib.cjs && dts-bundle-generator --export-referenced-types --no-check -o dist-lib/index.d.ts src/game/index.ts --project tsconfig.lib.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.5.32",
    "vue-i18n": "^11.4.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "cross-env": "^7.0.3",
    "dts-bundle-generator": "^9.5.1",
    "ts-loader": "^9.5.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1"
  }
}
